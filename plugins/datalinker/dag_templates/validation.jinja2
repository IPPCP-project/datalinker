import os
from airflow import DAG, Dataset
from airflow.operators.bash import BashOperator
from airflow.operators.python import PythonOperator
from airflow.providers.docker.operators.docker import DockerOperator
from datetime import datetime, timedelta
from airflow import configuration as conf
from docker.types import Mount

{{ ssot_id }}_ssot_rdf = Dataset("dl://{{ ssot_id }}/ssot-rdf")

{{ ssot_id }}_rdf_asserted = Dataset("dl://{{ ssot_id }}/rdf-asserted")
{{ ssot_id }}_rdf_asserted_inferred = Dataset("dl://{{ ssot_id }}/rdf-asserted-inferred")
{{ ssot_id }}_report = Dataset("dl://{{ ssot_id }}/report")

with DAG(
    dag_id="{{ ssot_id }}_validation", 
    description="RDF validation DAG for '{{ ssot_id }}' Single Source of Truth diagram",
    start_date=datetime(year=2025, month=2, day=1) , 
    catchup=False,
    schedule=[{{ ssot_id }}_ssot_rdf, {{ ssot_id }}_rdf_asserted] ,
    default_args={
        'owner': 'admin',
        'retries': 5,
        'retry_delay': timedelta(seconds=5)
    }
    ) as dag:

    validation = DockerOperator(
        docker_url="unix://var/run/docker.sock",  # replace it with swarm/docker endpoint tcp://localhost:2375
        image="ashleysommer/pyshacl:latest",
        auto_remove="force",
        network_mode="bridge",
        outlets = [{{ ssot_id }}_report],
        mounts=[
            Mount(source=os.path.join(conf.AIRFLOW_HOME, f"plugins/datalinker/data/{{ project_id }}"), target="/data", type="bind"),
        ], 
        task_id="validation",
        # do_xcom_push=True,
        command=[
            "poetry", "run", "pyshacl", "-s",
            "/data/ssot/{{ ssot_filename.split('.')[0] }}.ttl",
            "/data/rdf/{{ project_id }}-asserted.nt",
            #"-o", "/data/rdf/{{ project_id }}-report.ttl",
            "-f", "turtle"
            ],
        dag=dag,
    )
    validation

